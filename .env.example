# Copier vers .env (jamais commite) et renseigner ce dont tu as besoin.

# --- Trackers Torznab ---
# Passkeys de tes trackers, interpolees dans config.yaml via ${...}.
# Renomme/ajoute autant de variables que de trackers.
TRACKER1_API_KEY=
TRACKER2_API_KEY=

# --- Authentification (optionnelle) ---
# Renseigner les deux pour activer la connexion ; ce compte devient l'administrateur.
# Laisser vide pour un acces libre (ex. en local ou derriere un VPN).
TORSEARCH_USERNAME=
TORSEARCH_PASSWORD=
# Cle de signature des sessions (sinon generee dans data/.session_secret).
TORSEARCH_SECRET_KEY=
# Mettre a 1 si TorrSearch est servi derriere un reverse proxy HTTPS (cookie Secure).
TORSEARCH_HTTPS=

# --- Decouverte TMDB (optionnelle) ---
# Cle API gratuite : https://www.themoviedb.org/ (Parametres > API).
TMDB_API_KEY=
